# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# PostgreSQL / Prisma
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres

# Brevo
BREVO_API_KEY=your-brevo-api-key
BREVO_WEBHOOK_BEARER_TOKEN=your-brevo-webhook-token

# App
APP_BASE_URL=http://localhost:3000

# Cron (optional) — used by an external scheduler hitting /api/cron/* with `Authorization: Bearer <CRON_SECRET>`.
# Not needed on Vercel Cron (the x-vercel-cron header is trusted automatically).
CRON_SECRET=

# Mailbox credential encryption — encrypts stored IMAP and SMTP passwords
# (required for the Unibox / reply detection and for per-mailbox SMTP sending).
# Generate with: openssl rand -base64 32
MAILBOX_CREDENTIALS_KEY=

# Deliverability guardrails (optional — sensible defaults applied when unset).
GUARDRAIL_BOUNCE_RATE=0.05
GUARDRAIL_WARN_BOUNCE_RATE=0.03
GUARDRAIL_COMPLAINT_RATE=0.001
GUARDRAIL_MIN_VOLUME=30
